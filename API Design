#CampaignNotFoundException.java
/**
 * Thought Process:
 * Domain-specific exception improves readability
 * and centralized error handling.
 */
public class CampaignNotFoundException extends RuntimeException {

    public CampaignNotFoundException(String message) {
        super(message);
    }
}

#GlobalExceptionHandler.java
/**
 * Thought Process:
 * Convert internal exceptions into meaningful
 * HTTP responses for API consumers.
 */
@RestControllerAdvice
public class GlobalExceptionHandler {

    @ExceptionHandler(CampaignNotFoundException.class)
    public ResponseEntity<ErrorResponse> handle(CampaignNotFoundException ex) {
      return ResponseEntity.status(HttpStatus.NOT_FOUND)
              .body(
                  ErrorResponse.builder()
                          .timestamp(Instant.now())
                          .status(404)
                          .error("Campaign Not Found")
                          .message(ex.getMessage())
                          .build()
              );
    }
}

