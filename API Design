#InsightsController.java
/**
 * REST controller exposing campaign insight APIs.
 *
 * Thought Process:
 * Keep HTTP handling separate from business logic.
 */
@RequiredArgsConstructor
@RestController
@Validated
@RequestMapping("/api/v1/ad")
public class InsightsController {

    private final InsightsService insightsService;

    /**
     * Returns the total number of clicks for a campaign.
     *
     * @param campaignId Unique campaign identifier.
     * @return Click metrics for the campaign.
     */
    @GetMapping("/{campaignId}/clicks")
    public ResponseEntity<ClickResponse> getClicks(
            @PathVariable @NotBlank String campaignId) {
        ClickResponse response = insightsService.getClicks(campaignId);
        return ResponseEntity.ok(response);
    }
}

#InsightsService.java
/**
 * Business contract for retrieving campaign insights.
 *
 * Thought Process:
 * Centralize business rules in one place.
 */
public interface InsightsService {
    /**
     * Returns click metrics for a campaign.
     *
     * @param campaignId unique campaign identifier
     * @return click metrics
     */
    ClickResponse getClicks(String campaignId);
}

#InsightsServiceImpl.java
/**
 * Default implementation of the InsightsService.
 *
 * Thought Process:
 * Encapsulates business logic while keeping the controller
 * free from domain-specific decisions.
 */
@Service
@RequiredArgsConstructor
public class InsightsServiceImpl implements InsightsService {

    private static final Logger log =
            LoggerFactory.getLogger(InsightsServiceImpl.class);

    private final InsightsRepository repository;

    /**
     * Fetches click metrics for the given campaign.
     *
     * @param campaignId Unique campaign identifier.
     * @return ClickResponse containing campaign metrics.
     * @throws CampaignNotFoundException if campaign does not exist.
     */
    @Override
    public ClickResponse getClicks(String campaignId) {
        log.info("Fetching click metrics for campaign: {}", campaignId);
        Long clicks = repository.getClicks(campaignId);
        if (clicks == null) {
            log.warn("Campaign not found: {}", campaignId);
            throw new CampaignNotFoundException(
                    "Campaign '" + campaignId + "' not found."
            );
        }
        log.info("Successfully fetched click metrics for campaign: {}", campaignId);
        return ClickResponse.builder()
                .campaignId(campaignId)
                .clicks(clicks)
                .build();
    }
}

